# Databricks workspace host, with or without https://
DATABRICKS_HOST=https://adb-xxxxxxxxxxxx.x.azuredatabricks.net

# App Registration credentials (Service Principal)
DATABRICKS_CLIENT_ID=your-client-id
DATABRICKS_CLIENT_SECRET=your-client-secret

# Azure Entra tenant ID (required when using Azure App Registration flow)
AZURE_TENANT_ID=your-tenant-id

# SQL Warehouse to execute the query
DATABRICKS_SQL_WAREHOUSE_ID=your-sql-warehouse-id

# Optional defaults used by /api/databricks/tables
DATABRICKS_DEFAULT_CATALOG=main
DATABRICKS_DEFAULT_SCHEMA=default

# Backend port
PORT=3001
