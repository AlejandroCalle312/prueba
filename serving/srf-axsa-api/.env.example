# Databricks connection
DATABRICKS_WORKSPACE_URL=https://adb-xxxx.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxxxxxx

# Option A (recommended for local if available): Databricks PAT token
# DATABRICKS_TOKEN=dapi...

# Option B: Azure CLI / Azure identity auth (leave token empty)
DATABRICKS_TOKEN=

# Optional: override source table/view if needed
DATABRICKS_TICKETS_TABLE=axsa_prod_bronze.jira_tickets_mtb.tickets
# Optional: column used to count tickets
DATABRICKS_TICKET_ID_COLUMN=id
# Optional: assignment group column name in source table
DATABRICKS_ASSIGNED_GROUP_COLUMN=assigned_group

# API behavior
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3001,https://wonderful-stone-050229903.1.azurestaticapps.net
CACHE_TTL_SECONDS=60
LOG_LEVEL=INFO

# Optional local cache invalidation secret
CACHE_INVALIDATION_TOKEN=
